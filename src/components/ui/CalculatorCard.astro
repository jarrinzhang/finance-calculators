---
/**
 * CalculatorCard - 首页/列表页用的计算器卡片
 */
import type { CalculatorMeta } from "../../data/calculators";

export interface Props {
  calculator: CalculatorMeta;
}

const { calculator } = Astro.props;
---

<a
  href={calculator.path}
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
>
  <!-- 渐变色块（左侧装饰条） -->
  <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${calculator.accent}`}></div>

  <!-- 图标 -->
  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gray-50 text-2xl">
    <span aria-hidden="true">{calculator.emoji}</span>
  </div>

  <!-- 标题 -->
  <h3 class="mt-4 text-lg font-bold text-gray-900 group-hover:text-brand-800">
    {calculator.name}
  </h3>

  <!-- 描述 -->
  <p class="mt-2 flex-1 text-sm text-gray-600">{calculator.shortDesc}</p>

  <!-- CTA -->
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700">
    Open calculator
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      class="h-4 w-4 transition group-hover:translate-x-0.5"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </span>
</a>
