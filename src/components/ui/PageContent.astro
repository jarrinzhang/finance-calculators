---
/**
 * PageContent - 静态文本页面（Privacy/Terms/About/Contact）的统一容器
 */
export interface Props {
  title: string;
  subtitle?: string;
  lastUpdated?: string;
}
const { title, subtitle, lastUpdated } = Astro.props;
---

<article class="mx-auto max-w-3xl">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{title}</h1>
    {subtitle && <p class="mt-2 text-gray-600">{subtitle}</p>}
    {lastUpdated && (
      <p class="mt-2 text-sm text-gray-500">Last updated: {lastUpdated}</p>
    )}
  </header>
  <div class="prose prose-sm prose-gray max-w-none prose-h2:text-xl prose-h2:font-bold prose-h2:text-gray-900 prose-h3:text-lg prose-h3:font-semibold prose-h3:text-gray-900 prose-a:text-brand-700">
    <slot />
  </div>
</article>
