---
/**
 * BlogPost - 单篇 blog 文章的布局
 *
 * 复用 BaseLayout，包裹 Markdown 渲染的正文。
 * 包含：面包屑 / 文章头部（标题、日期、作者、阅读时间、tags）/ prose 正文 / CTA
 */
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

export interface Props {
  entry: CollectionEntry<"blog">;
  /** render() 返回的 Content 组件 */
  Content: any;
  /** 阅读时间（分钟） */
  readingTime: number;
}

const { entry, Content, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, relatedCalculator } = entry.data;

const path = `/blog/${entry.id}`;
const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

// Article JSON-LD（提升搜索富结果曝光）
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { "@type": "Organization", name: author },
  publisher: {
    "@type": "Organization",
    name: "FinCalc Hub",
    url: "https://finance-calculators-a0a.pages.dev",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(path, Astro.site).href,
  },
};
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  jsonLd={jsonLd}
  containerClass="mx-auto max-w-3xl px-4 py-8"
>
  <!-- 面包屑 -->
  <nav class="mb-4 text-sm text-gray-500" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-700">Home</a>
    <span class="mx-2">/</span>
    <a href="/blog" class="hover:text-brand-700">Blog</a>
    <span class="mx-2">/</span>
    <span class="text-gray-700">{title}</span>
  </nav>

  <!-- 文章头部 -->
  <header class="mb-8 border-b border-gray-200 pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{title}</h1>
    <p class="mt-3 text-lg text-gray-600">{description}</p>
    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500">
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <time datetime={pubDate.toISOString()}>{fmtDate(pubDate)}</time>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        {readingTime} min read
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        {author}
      </span>
    </div>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag: string) => (
          <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-700">
            #{tag}
          </span>
        ))}
      </div>
    )}
    {updatedDate && (
      <p class="mt-3 text-xs text-gray-400 italic">Updated: {fmtDate(updatedDate)}</p>
    )}
  </header>

  <!-- 正文（prose 排版） -->
  <div class="prose prose-lg prose-gray max-w-none prose-headings:scroll-mt-20 prose-headings:font-bold prose-a:text-brand-700 prose-a:font-medium hover:prose-a:text-brand-900 prose-strong:text-gray-900 prose-blockquote:border-brand-300">
    <Content />
  </div>

  <!-- CTA：导流给计算器 -->
  {relatedCalculator && (
    <div class="not-prose my-10 rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-brand-100 p-6">
      <h2 class="text-lg font-bold text-gray-900">Try it yourself</h2>
      <p class="mt-1 text-sm text-gray-600">
        Numbers are better when they're your numbers. Run your own numbers with our free calculator.
      </p>
      <a
        href={relatedCalculator}
        class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand-800 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-900"
      >
        Open Calculator
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  )}

  <!-- 返回列表链接 -->
  <div class="not-prose mt-10 border-t border-gray-200 pt-6">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-700 hover:text-brand-900">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to all articles
    </a>
  </div>
</BaseLayout>
