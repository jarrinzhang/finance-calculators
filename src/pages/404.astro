---
/**
 * 404 页面
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The page you were looking for could not be found."
  path="/404"
>
  <div class="mx-auto max-w-xl py-20 text-center">
    <p class="text-7xl font-bold text-brand-800">404</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900">Page not found</h1>
    <p class="mt-2 text-gray-600">
      Sorry, we couldn't find the page you were looking for. It may have been moved or deleted.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="rounded-lg bg-brand-800 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-900"
      >
        Back to home
      </a>
      <a
        href="/calculators/mortgage-calculator"
        class="rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50"
      >
        Try our mortgage calculator
      </a>
    </div>
  </div>
</BaseLayout>
