---
/**
 * Blog 列表页 - /blog
 *
 * 按 pubDate 倒序列出所有文章
 */
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Financial Guides & Insights";
const description =
  "Practical guides on mortgages, loans, investing, and personal finance. Clear explanations, real numbers, and free calculators to help you make better money decisions.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", Astro.site).href },
    { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog", Astro.site).href },
  ],
};

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout title={title} description={description} path="/blog" jsonLd={jsonLd} containerClass="mx-auto max-w-5xl px-4 py-10">
  <nav class="mb-4 text-sm text-gray-500" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-700">Home</a>
    <span class="mx-2">/</span>
    <span class="text-gray-700">Blog</span>
  </nav>

  <header class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Financial Guides & Insights</h1>
    <p class="mt-3 max-w-2xl text-lg text-gray-600">
      Practical, no-nonsense guides on mortgages, loans, investing, and personal finance — with real numbers and free calculators.
    </p>
  </header>

  {posts.length === 0 ? (
    <p class="text-gray-500">No articles yet. Check back soon!</p>
  ) : (
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {posts.map((post) => (
        <article class="group flex flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md">
          <div class="mb-3 flex items-center gap-2 text-xs text-gray-500">
            <time datetime={post.data.pubDate.toISOString()}>
              {fmtDate(post.data.pubDate)}
            </time>
            <span>·</span>
            <span>{post.data.readingTime ?? 5} min read</span>
          </div>

          <h2 class="text-xl font-bold text-gray-900 group-hover:text-brand-800">
            <a href={`/blog/${post.id}`} class="after:absolute after:inset-0">
              {post.data.title}
            </a>
          </h2>

          <p class="mt-2 flex-1 text-sm text-gray-600">{post.data.description}</p>

          {post.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-1.5">
              {post.data.tags.slice(0, 3).map((tag: string) => (
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">
                  #{tag}
                </span>
              ))}
            </div>
          )}

          <span class="relative z-10 mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700">
            Read more
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4 transition group-hover:translate-x-0.5">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </article>
      ))}
    </div>
  )}
</BaseLayout>
