---
/**
 * 首页 - 介绍站点 + 5 个计算器卡片网格
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import CalculatorCard from "../components/ui/CalculatorCard.astro";
import { calculators } from "../data/calculators";

const title = "Free Financial Calculators";
const description =
  "Free, fast, and accurate financial calculators. Plan your mortgage, loans, investments, retirement, and auto financing with our easy-to-use tools.";
---

<BaseLayout
  title={title}
  description={description}
  path="/"
  containerClass="mx-auto max-w-6xl px-4 py-10"
>
  <!-- Hero -->
  <section class="text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-brand-600"></span>
      100% Free · No sign-up · No ads on this page
    </span>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      Smart Financial Calculators
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
      Make confident money decisions with our free, accurate, and lightning-fast calculators.
      From mortgages to retirement planning &mdash; we've got you covered.
    </p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm text-gray-500">
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4 text-brand-600">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Accurate formulas
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4 text-brand-600">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Privacy-first (no data leaves your browser)
      </span>
      <span class="inline-flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-4 w-4 text-brand-600">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Works on mobile
      </span>
    </div>
  </section>

  <!-- Calculators Grid -->
  <section class="mt-12">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {calculators.map((calc) => <CalculatorCard calculator={calc} />)}
    </div>
  </section>

  <!-- Why trust us -->
  <section class="mt-16 rounded-2xl bg-gradient-to-br from-brand-800 to-brand-950 p-8 text-white sm:p-12">
    <h2 class="text-2xl font-bold sm:text-3xl">Why use our calculators?</h2>
    <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-3">
      <div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3 class="mt-3 font-semibold">Bank-grade formulas</h3>
        <p class="mt-1 text-sm text-white/80">
          We use the same standard amortization and compound interest formulas trusted by banks and financial advisors.
        </p>
      </div>
      <div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
            <rect x="3" y="11" width="18" height="11" rx="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <h3 class="mt-3 font-semibold">100% private</h3>
        <p class="mt-1 text-sm text-white/80">
          Your numbers never leave your device. All calculations run locally in your browser &mdash; nothing is stored or tracked.
        </p>
      </div>
      <div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <h3 class="mt-3 font-semibold">Instant results</h3>
        <p class="mt-1 text-sm text-white/80">
          See your monthly payment, total interest, and full amortization schedule the moment you type &mdash; no waiting, no refreshes.
        </p>
      </div>
    </div>
  </section>

  <!-- SEO 内容段落（首页关键词布局）-->
  <section class="mt-16 max-w-3xl">
    <h2 class="text-2xl font-bold text-gray-900">Free financial tools for every life decision</h2>
    <div class="prose prose-sm mt-4 max-w-none text-gray-600">
      <p>
        Whether you're buying your first home, comparing personal loan offers, or planning for
        retirement, having the right numbers matters. Our suite of free financial calculators
        helps you understand the true cost of borrowing and the long-term power of saving.
      </p>
      <p class="mt-3">
        Use the <a href="/calculators/mortgage-calculator" class="text-brand-700 underline">mortgage calculator</a>
        to estimate monthly house payments and view a full amortization schedule. The
        <a href="/calculators/loan-calculator" class="text-brand-700 underline">loan calculator</a>
        works for personal loans, student loans, and any fixed-rate borrowing. See how your
        savings grow with the
        <a href="/calculators/compound-interest-calculator" class="text-brand-700 underline">compound interest calculator</a>,
        and project your retirement nest egg with the
        <a href="/calculators/retirement-calculator" class="text-brand-700 underline">retirement calculator</a>.
        Shopping for a car? The
        <a href="/calculators/auto-loan-calculator" class="text-brand-700 underline">auto loan calculator</a>
        factors in down payment, trade-in, and sales tax.
      </p>
      <p class="mt-3">
        All calculations happen instantly in your browser &mdash; no waiting, no sign-ups, no
        data collection. Bookmark this page and come back any time you need a quick financial
        estimate.
      </p>
    </div>
  </section>
</BaseLayout>
