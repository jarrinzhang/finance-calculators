---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CDCalculator from "../../components/calculators/CDCalculator.tsx";
import RelatedCalculators from "../../components/calculators/RelatedCalculators.astro";
import { getCalculator } from "../../data/calculators";

const slug = "cd-calculator";
const calc = getCalculator(slug)!;
const path = `/calculators/${slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: calc.name,
  url: new URL(path, Astro.site).href,
  description: calc.seoDescription,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Any (Web Browser)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  isAccessibleForFree: true,
};
---

<BaseLayout title={calc.name} description={calc.seoDescription} path={path} jsonLd={jsonLd} showTopAd={true}>
  <nav class="mb-4 text-sm text-gray-500" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand-700">Home</a>
    <span class="mx-2">/</span>
    <span class="text-gray-700">{calc.name}</span>
  </nav>

  <header class="mb-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{calc.name}</h1>
    <p class="mt-2 text-gray-600">{calc.shortDesc}</p>
  </header>

  <CDCalculator client:load />

  <section class="mt-12 max-w-3xl prose prose-sm prose-gray">
    <h2 class="text-xl font-bold text-gray-900">What is a Certificate of Deposit (CD)?</h2>
    <p>
      A CD is a time deposit offered by banks and credit unions. You agree to lock up your money
      for a fixed term (typically 6 months to 5 years), and in exchange, the bank pays you a
      guaranteed interest rate &mdash; usually higher than a regular savings account. Withdraw early,
      and you'll typically pay a penalty of 3&ndash;12 months of interest.
    </p>

    <h3 class="text-lg font-semibold text-gray-900 mt-6">How CD interest is calculated</h3>
    <p>
      Banks usually quote CDs in APY (Annual Percentage Yield), which already includes the effect
      of compounding. Most CDs compound daily. For example, a $10,000 CD at 5% APY for 1 year with
      daily compounding grows to $10,512.67 &mdash; slightly more than the simple $500 you'd get
      from 5% simple interest.
    </p>
    <p class="rounded-lg bg-gray-50 px-4 py-3 font-mono text-sm">
      Final Value = Principal × (1 + APY/365)<sup>365 × years</sup>
    </p>

    <h3 class="text-lg font-semibold text-gray-900 mt-6">CD rates (2026 landscape)</h3>
    <ul>
      <li><strong>6-month CD:</strong> 4.5&ndash;5.0% APY</li>
      <li><strong>1-year CD:</strong> 4.7&ndash;5.3% APY (often the sweet spot)</li>
      <li><strong>3-year CD:</strong> 4.0&ndash;4.5% APY</li>
      <li><strong>5-year CD:</strong> 3.8&ndash;4.3% APY</li>
    </ul>
    <p class="text-sm">
      Note the "inverted curve" &mdash; shorter terms often pay <em>more</em> than longer terms. This
      happens when markets expect interest rates to fall. Online banks and credit unions typically
      offer the best CD rates, far better than big national banks.
    </p>

    <h3 class="text-lg font-semibold text-gray-900 mt-6">When a CD makes sense</h3>
    <ul>
      <li>You have a known future expense (down payment, tuition) and won't need the money before maturity</li>
      <li>You want a guaranteed return with zero market risk</li>
      <li>Rates are high and you want to lock them in long-term</li>
      <li>You've maxed out tax-advantaged accounts (401k, IRA) and need a stable cash holding</li>
    </ul>

    <h3 class="text-lg font-semibold text-gray-900 mt-6">CD ladders</h3>
    <p>
      A "CD ladder" splits your money across CDs of different maturities (e.g., 1, 2, 3, 4, 5-year
      CDs). As each matures, you reinvest into a new 5-year CD. This gives you regular access to
      cash while capturing the higher long-term rates &mdash; a popular strategy for conservative
      savers.
    </p>
  </section>

  <RelatedCalculators currentSlug={slug} />
</BaseLayout>
